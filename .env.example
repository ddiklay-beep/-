# ============================================================
# .env.example  —  קובץ תבנית. מועתק ל-.env ונערך עם ערכים אמיתיים.
# הקובץ הזה כן מועלה ל-Git. הקובץ .env לא.
# ============================================================

# Anthropic API key — נדרש רק אם הצוות קורא ל-Anthropic API ישירות
# (לא דרך Claude Code). ניתן להשיג ב-https://console.anthropic.com
ANTHROPIC_API_KEY=

# מודל ברירת מחדל לסוכנים (אופציונלי). דוגמה: claude-opus-4-7
ANTHROPIC_MODEL=

# OpenAI API key — נדרש ע"י הסקיל gpt-image-gen (יצירת תמונות עבור יובל).
# המפתח נשלף ב-Bash ע"י `set -a; source .env; set +a` לפני קריאה לסקיל.
OPENAI_API_KEY=

# הוסיפו כאן משתני סביבה נוספים בהמשך הסדנה לפי הצורך של הצוות
# (למשל מפתח API לכלי מחקר עבור חן).
